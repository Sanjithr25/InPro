# ─── Core ────────────────────────────────────────────────────────────────────
# Supabase Postgres (Transaction Pooler recommended)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Phase 1: groq  |  Later: anthropic | openai | gemini
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Groq (Phase 1 — fast inference, free tier available at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (Phase 2+)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
