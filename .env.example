# ─── Core ────────────────────────────────────────────────────────────────────
# Supabase Postgres (Transaction Pooler recommended)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── LLM Provider Configuration ──────────────────────────────────────────────
# Default provider (fallback if not configured in DB)
# Options: llama-local | ollama | groq | gemini | openai | anthropic | custom
LLM_PROVIDER=llama-local
LLM_MODEL=llama3.2

# ─── Provider API Keys ───────────────────────────────────────────────────────
# These are fallback values if not configured in the database via LLM Settings UI
# Users can add providers dynamically through the UI without editing this file

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Groq (fast inference, free tier available at console.groq.com)
GROQ_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ─── Provider Base URLs (Optional) ───────────────────────────────────────────
# Override default endpoints if needed

# Ollama Cloud (for user-configured instances)
OLLAMA_BASE_URL=

# Groq (default: https://api.groq.com/openai/v1)
GROQ_BASE_URL=

# Gemini (default: https://generativelanguage.googleapis.com/v1beta/openai/)
GEMINI_BASE_URL=

# Custom OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
